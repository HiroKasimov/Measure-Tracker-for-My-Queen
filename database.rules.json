{
  "rules": {
    "cycleTracker": {
      ".read": "auth != null && root.child('approvals').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('approvals').child(auth.uid).child('status').val() === 'approved'"
    },
    "cycleTrackerMeta": {
      ".read": "auth != null && root.child('approvals').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('approvals').child(auth.uid).child('status').val() === 'approved'"
    },
    "approvals": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || auth.uid === 'M2Ep9UAWVfMP78Ofj8FWjTNXvFH2')",
        ".write": "auth != null && (auth.uid === 'M2Ep9UAWVfMP78Ofj8FWjTNXvFH2' || ($uid === auth.uid && !data.exists()))"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
